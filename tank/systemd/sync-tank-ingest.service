[Unit]
Description=Sync Tank ESP32 camera ingest receiver
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=one
WorkingDirectory=/home/one/Projects/sync-tank/tank
Environment=PYTHONPATH=/home/one/Projects/sync-tank/tank
ExecStart=/home/one/Projects/sync-tank/tank/scripts/run-ingest.sh
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
